{
  "name": "kags-crime-legend",
  "version": "1.0.0",
  "description": "Production-ready crime legend component with 90-day time decay visualization. Extracted from the KAGS (Crime-Aware Routing) project.",
  "main": "dist/vanilla-js/CrimeLegend.js",
  "types": "dist/types/index.d.ts",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && webpack",
    "build:react": "tsc --module esnext",
    "dev": "webpack-dev-server",
    "test": "jest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "prepublish": "npm run build"
  },
  "keywords": [
    "crime",
    "legend",
    "visualization",
    "time-decay",
    "map",
    "heatmap",
    "safety",
    "react",
    "component",
    "geospatial",
    "kags"
  ],
  "author": "Kyle",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/kags-crime-legend"
  },
  "bugs": {
    "url": "https://github.com/yourusername/kags-crime-legend/issues"
  },
  "homepage": "https://github.com/yourusername/kags-crime-legend",
  "engines": {
    "node": ">=14.0.0"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0"
  },
  "peerDependenciesOptional": {
    "react": true
  },
  "devDependencies": {
    "@types/react": "^18.0.0",
    "@types/node": "^18.0.0",
    "typescript": "^4.8.0",
    "eslint": "^8.0.0",
    "prettier": "^3.0.0",
    "jest": "^29.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0",
    "webpack-dev-server": "^4.0.0"
  },
  "optionalDependencies": {
    "tailwindcss": "^3.0.0"
  },
  "exports": {
    ".": {
      "require": "./dist/vanilla-js/CrimeLegend.js",
      "import": "./dist/react/CrimeLegend.js",
      "types": "./dist/types/index.d.ts"
    },
    "./react": {
      "require": "./dist/react/CrimeLegend.js",
      "import": "./dist/react/CrimeLegend.js",
      "types": "./dist/types/react.d.ts"
    },
    "./vanilla": {
      "require": "./dist/vanilla-js/CrimeLegend.js",
      "import": "./dist/vanilla-js/CrimeLegend.js",
      "types": "./dist/types/vanilla.d.ts"
    }
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead"
  ],
  "publishConfig": {
    "access": "public"
  }
}
